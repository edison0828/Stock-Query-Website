generator client {
  provider      = "prisma-client-js"
  output        = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model alertrules {
  alert_rule_id              BigInt          @id @default(autoincrement())
  user_id                    BigInt
  stock_id                   String          @db.VarChar(20)
  rule_type                  alert_rule_type
  threshold_value            Decimal         @db.Decimal(18, 6)
  is_active                  Boolean         @default(true)
  last_triggered_market_date DateTime?       @db.Date
  created_at                 DateTime        @default(now()) @db.Timestamp(0)
  notifications              notifications[]
  stocks                     stocks          @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_AlertRules_Stocks1")
  users                      users           @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_AlertRules_Users1")

  @@index([stock_id], map: "fk_AlertRules_Stocks1_idx")
  @@index([user_id, is_active], map: "idx_alertrules_user_active")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model dividends {
  stock_id                String   @db.VarChar(20)
  dividend_date           DateTime @db.Date
  pre_ex_dividend_close   Decimal? @db.Decimal(18, 6)
  reference_price         Decimal? @db.Decimal(18, 6)
  dividend_value          Decimal? @db.Decimal(18, 6)
  ex_type                 String?  @db.VarChar(20)
  opening_reference_price Decimal? @db.Decimal(18, 6)
  adjusted_price          Decimal? @db.Decimal(18, 6)
  stocks                  stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_Dividends_Stocks1")

  @@id([stock_id, dividend_date])
  @@index([stock_id], map: "fk_Dividends_Stocks1_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model financialreports {
  stock_id                     String   @db.VarChar(20)
  year                         BigInt
  period_type                  String   @db.VarChar(20)
  eps                          Decimal? @db.Decimal(10, 4)
  revenue                      BigInt?
  Income                       BigInt?
  non_operating_income_expense BigInt?
  net_income                   BigInt?
  stocks                       stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_financialreports_stocks1")

  @@id([stock_id, period_type, year])
  @@unique([stock_id, period_type, year], map: "uq_stock_report_period")
  @@index([stock_id], map: "fk_FinancialReports_Stocks1_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model historicalprices {
  stock_id         String   @db.VarChar(20)
  date             DateTime @db.Date
  open_price       Decimal? @db.Decimal(18, 6)
  high_price       Decimal? @db.Decimal(18, 6)
  low_price        Decimal? @db.Decimal(18, 6)
  close_price      Decimal? @db.Decimal(18, 6)
  volume           BigInt?
  number_of_trades BigInt?
  trading_value    BigInt?
  stocks           stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_historicalprices_stocks1")

  @@id([stock_id, date])
  @@index([stock_id, date(sort: Desc)], map: "idx_historicalprices_stock_date")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model portfolios {
  portfolio_id   BigInt         @id @default(autoincrement())
  user_id        BigInt
  portfolio_name String         @db.VarChar(100)
  description    String?        @db.Text
  created_at     DateTime       @default(now()) @db.Timestamp(0)
  users          users          @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_Portfolios_Users1")
  transactions   transactions[]

  @@unique([user_id, portfolio_name], map: "uq_user_portfolio_name")
  @@index([user_id], map: "fk_Portfolios_Users1_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model stocks {
  stock_id          String                     @id @db.VarChar(20)
  company_name      String                     @db.VarChar(255)
  market_type       String                     @db.VarChar(255)
  asset_type        String                     @default("STOCK") @db.VarChar(20)
  industry_category String?                    @db.VarChar(100)
  security_status   String                     @db.VarChar(255)
  transfer_agent    String                     @db.VarChar(255)
  currency          String                     @db.VarChar(10)
  alertrules        alertrules[]
  backtestruns      backtestruns[]
  dividends         dividends[]
  financialreports  financialreports[]
  historicalprices  historicalprices[]
  notifications     notifications[]
  stocksplits       stocksplits[]
  transactions      transactions[]
  watchlistitems    watchlistitems[]
  qualitychecks     marketdataqualitychecks[]
  qualityignores    marketdataqualityignores[]
  etfprofile        etfprofiles?
  etfnavsnapshots   etfnavsnapshots[]
  etfholdings       etfholdings[]

  @@index([company_name], map: "idx_stocks_company_name")
  @@index([market_type], map: "idx_stocks_market_type")
  @@index([asset_type], map: "idx_stocks_asset_type")
  @@index([industry_category], map: "idx_stocks_industry_category")
  @@index([stock_id, company_name], map: "idx_stocks_search")
  @@index([security_status], map: "idx_stocks_security_status")
}

model etfprofiles {
  stock_id               String    @id @db.VarChar(20)
  fund_short_name        String?   @db.VarChar(255)
  fund_name              String?   @db.VarChar(255)
  fund_english_name      String?   @db.VarChar(255)
  issuer                 String?   @db.VarChar(255)
  etf_category           String?   @db.VarChar(255)
  tracking_index         String?   @db.VarChar(500)
  is_custom_index        String?   @db.VarChar(100)
  has_foreign_components Boolean?
  benchmark_name         String?   @db.VarChar(255)
  benchmark_english_name String?   @db.VarChar(255)
  inception_date         DateTime? @db.Date
  listing_date           DateTime? @db.Date
  fund_manager           String?   @db.VarChar(100)
  custodian              String?   @db.VarChar(255)
  units_outstanding      BigInt?
  mops_fund_id           String?   @db.VarChar(50)
  detail_url             String?   @db.VarChar(500)
  expense_ratio          Decimal?  @db.Decimal(10, 4)
  management_fee_rate    Decimal?  @db.Decimal(10, 4)
  custodian_fee_rate     Decimal?  @db.Decimal(10, 4)
  expense_ratio_period   String?   @db.VarChar(50)
  fee_source             String?   @db.VarChar(100)
  data_source            String    @default("FINLAB_TWSE_OPENAPI") @db.VarChar(100)
  source_as_of_date      DateTime? @db.Date
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  stocks                 stocks    @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_EtfProfiles_Stocks1")

  @@index([etf_category], map: "idx_etfprofiles_category")
  @@index([tracking_index], map: "idx_etfprofiles_tracking_index")
  @@index([issuer], map: "idx_etfprofiles_issuer")
}

model etfnavsnapshots {
  nav_id           BigInt   @id @default(autoincrement())
  stock_id         String   @db.VarChar(20)
  date             DateTime @db.Date
  nav              Decimal? @db.Decimal(18, 6)
  premium_discount Decimal? @db.Decimal(10, 4)
  data_source      String   @default("FINLAB") @db.VarChar(100)
  created_at       DateTime @default(now()) @db.Timestamp(0)
  stocks           stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_EtfNavSnapshots_Stocks1")

  @@unique([stock_id, date], map: "uq_etfnavsnapshots_stock_date")
  @@index([stock_id, date(sort: Desc)], map: "idx_etfnavsnapshots_stock_date")
}

model etfholdings {
  holding_id            BigInt   @id @default(autoincrement())
  stock_id              String   @db.VarChar(20)
  component_symbol      String   @db.VarChar(30)
  component_name        String   @db.VarChar(255)
  snapshot_date         DateTime @db.Date
  weight                Decimal? @db.Decimal(10, 4)
  shares                BigInt?
  component_close_price Decimal? @db.Decimal(18, 6)
  component_change_pct  Decimal? @db.Decimal(10, 4)
  contribution_pct      Decimal? @db.Decimal(10, 4)
  component_industry    String?  @db.VarChar(100)
  holding_rank          Int?
  data_source           String   @default("ETFINFO_PUBLIC_PAGE") @db.VarChar(100)
  source_url            String?  @db.VarChar(500)
  created_at            DateTime @default(now()) @db.Timestamp(0)
  stocks                stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_EtfHoldings_Stocks1")

  @@unique([stock_id, component_symbol, snapshot_date], map: "uq_etfholdings_stock_component_date")
  @@index([stock_id, snapshot_date, weight(sort: Desc)], map: "idx_etfholdings_stock_date_weight")
  @@index([component_symbol], map: "idx_etfholdings_component_symbol")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model stocksplits {
  split_id           BigInt   @id @default(autoincrement())
  stock_id           String   @db.VarChar(20)
  split_date         DateTime @db.Date
  split_ratio_before Decimal  @db.Decimal(10, 4)
  split_ratio_after  Decimal  @db.Decimal(10, 4)
  stocks             stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_stocksplits_stocks1")

  @@index([stock_id], map: "fk_StockSplits_Stocks1_idx")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model test {
  my_row_id BigInt   @id @db.UnsignedBigInt
  stock_id  String   @db.VarChar(11)
  date      DateTime @db.Date
  open      Float    @db.Float
  close     Float    @db.Float

  @@ignore
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model transactions {
  transaction_id   BigInt                        @id @default(autoincrement())
  portfolio_id     BigInt
  stock_id         String                        @db.VarChar(20)
  transaction_type transactions_transaction_type
  transaction_date DateTime                      @default(now()) @db.Timestamp(0)
  quantity         Decimal                       @db.Decimal(18, 6)
  price_per_share  Decimal                       @db.Decimal(18, 6)
  commission       Decimal?                      @default(0.00) @db.Decimal(10, 2)
  currency         String                        @db.VarChar(10)
  portfolios       portfolios                    @relation(fields: [portfolio_id], references: [portfolio_id], onDelete: Cascade, map: "fk_Transactions_Portfolios1")
  stocks           stocks                        @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_Transactions_stocks1")

  @@index([portfolio_id], map: "fk_Transactions_Portfolios1_idx")
  @@index([stock_id], map: "fk_Transactions_Stocks1_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model users {
  user_id                  BigInt                     @id @default(autoincrement())
  username                 String                     @unique(map: "username_UNIQUE") @db.VarChar(100)
  email                    String                     @unique(map: "email_UNIQUE") @db.VarChar(255)
  password_hash            String?                    @db.VarChar(255)
  created_at               DateTime                   @default(now()) @db.Timestamp(0)
  last_login               DateTime?                  @db.Timestamp(0)
  google_id                String?                    @unique(map: "google_id") @db.VarChar(255)
  role                     String                     @default("user") @db.VarChar(255)
  alertrules               alertrules[]
  backtestruns             backtestruns[]
  marketdatasyncjobs       marketdatasyncjobs[]
  marketdataqualityignores marketdataqualityignores[]
  notifications            notifications[]
  portfolios               portfolios[]
  watchlistitems           watchlistitems[]
}

model marketdatasyncjobs {
  sync_job_id           BigInt                    @id @default(autoincrement())
  requested_source      String                    @db.VarChar(20)
  resolved_source       String?                   @db.VarChar(20)
  scope                 String                    @db.VarChar(20)
  status                String                    @default("RUNNING") @db.VarChar(20)
  started_at            DateTime                  @default(now()) @db.Timestamp(0)
  finished_at           DateTime?                 @db.Timestamp(0)
  duration_ms           BigInt?
  command               String?                   @db.Text
  skip_stocks           Boolean                   @default(false)
  skip_prices           Boolean                   @default(false)
  skip_financials       Boolean                   @default(false)
  skip_dividends        Boolean                   @default(false)
  stock_rows            BigInt?
  historical_price_rows BigInt?
  financial_report_rows BigInt?
  dividend_rows         BigInt?
  latest_price_date     DateTime?                 @db.Date
  fallback_reason       String?                   @db.Text
  stdout_tail           String?                   @db.Text
  stderr_tail           String?                   @db.Text
  error_message         String?                   @db.Text
  created_by_user_id    BigInt?
  users                 users?                    @relation(fields: [created_by_user_id], references: [user_id], onDelete: SetNull, map: "fk_MarketDataSyncJobs_Users1")
  qualitychecks         marketdataqualitychecks[]

  @@index([created_by_user_id], map: "fk_MarketDataSyncJobs_Users1_idx")
  @@index([status, started_at(sort: Desc)], map: "idx_marketdatasyncjobs_status_started")
  @@index([started_at(sort: Desc)], map: "idx_marketdatasyncjobs_started")
}

model marketdataqualitychecks {
  quality_check_id   BigInt              @id @default(autoincrement())
  sync_job_id        BigInt?
  check_type         String              @db.VarChar(80)
  stock_id           String?             @db.VarChar(20)
  severity           String              @db.VarChar(20)
  message            String              @db.Text
  observed_value     String?             @db.Text
  created_at         DateTime            @default(now()) @db.Timestamp(0)
  marketdatasyncjobs marketdatasyncjobs? @relation(fields: [sync_job_id], references: [sync_job_id], onDelete: SetNull, map: "fk_MarketDataQualityChecks_SyncJobs1")
  stocks             stocks?             @relation(fields: [stock_id], references: [stock_id], onDelete: SetNull, map: "fk_MarketDataQualityChecks_Stocks1")

  @@index([sync_job_id], map: "fk_MarketDataQualityChecks_SyncJobs1_idx")
  @@index([stock_id], map: "fk_MarketDataQualityChecks_Stocks1_idx")
  @@index([check_type, severity], map: "idx_marketdataqualitychecks_type_severity")
  @@index([created_at(sort: Desc)], map: "idx_marketdataqualitychecks_created")
}

model marketdataqualityignores {
  ignore_id          BigInt   @id @default(autoincrement())
  stock_id           String   @db.VarChar(20)
  check_type         String   @db.VarChar(80)
  reason             String?  @db.Text
  created_at         DateTime @default(now()) @db.Timestamp(0)
  created_by_user_id BigInt?
  stocks             stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_MarketDataQualityIgnores_Stocks1")
  users              users?   @relation(fields: [created_by_user_id], references: [user_id], onDelete: SetNull, map: "fk_MarketDataQualityIgnores_Users1")

  @@unique([stock_id, check_type], map: "uq_marketdataqualityignores_stock_check")
  @@index([created_by_user_id], map: "fk_MarketDataQualityIgnores_Users1_idx")
  @@index([check_type], map: "idx_marketdataqualityignores_check_type")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model watchlistitems {
  user_id  BigInt
  stock_id String   @db.VarChar(20)
  added_at DateTime @default(now()) @db.Timestamp(0)
  notes    String?  @db.Text
  users    users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_WatchlistItems_Users1")
  stocks   stocks   @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_Watchlistitems_stocks1")

  @@id([user_id, stock_id])
  @@index([stock_id], map: "fk_WatchlistItems_Stocks1_idx")
}

model notifications {
  notification_id BigInt      @id @default(autoincrement())
  user_id         BigInt
  alert_rule_id   BigInt?
  stock_id        String      @db.VarChar(20)
  title           String      @db.VarChar(255)
  message         String      @db.Text
  is_read         Boolean     @default(false)
  created_at      DateTime    @default(now()) @db.Timestamp(0)
  alertrules      alertrules? @relation(fields: [alert_rule_id], references: [alert_rule_id], onDelete: SetNull, map: "fk_Notifications_AlertRules1")
  stocks          stocks      @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_Notifications_Stocks1")
  users           users       @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_Notifications_Users1")

  @@index([alert_rule_id], map: "fk_Notifications_AlertRules1_idx")
  @@index([stock_id], map: "fk_Notifications_Stocks1_idx")
  @@index([user_id, is_read, created_at(sort: Desc)], map: "idx_notifications_user_read_created")
}

model backtestruns {
  backtest_run_id           BigInt                 @id @default(autoincrement())
  user_id                   BigInt
  stock_id                  String                 @db.VarChar(20)
  strategy_type             backtest_strategy_type
  strategy_name             String                 @db.VarChar(100)
  start_date                DateTime               @db.Date
  end_date                  DateTime               @db.Date
  initial_capital           Decimal                @db.Decimal(18, 6)
  final_value               Decimal                @db.Decimal(18, 6)
  total_return_percent      Decimal                @db.Decimal(10, 4)
  max_drawdown_percent      Decimal                @db.Decimal(10, 4)
  win_rate_percent          Decimal                @db.Decimal(10, 4)
  trade_count               Int
  signal_count              Int
  short_window              Int?
  long_window               Int?
  parameters                Json?
  execution_config          Json?
  annualized_return_percent Decimal?               @db.Decimal(10, 4)
  profit_factor             Decimal?               @db.Decimal(10, 4)
  average_win_percent       Decimal?               @db.Decimal(10, 4)
  average_loss_percent      Decimal?               @db.Decimal(10, 4)
  max_consecutive_losses    Int?
  equity_curve              Json?
  created_at                DateTime               @default(now()) @db.Timestamp(0)
  backtesttrades            backtesttrades[]
  stocks                    stocks                 @relation(fields: [stock_id], references: [stock_id], onDelete: Cascade, map: "fk_BacktestRuns_Stocks1")
  users                     users                  @relation(fields: [user_id], references: [user_id], onDelete: Cascade, map: "fk_BacktestRuns_Users1")

  @@index([stock_id], map: "fk_BacktestRuns_Stocks1_idx")
  @@index([user_id, created_at(sort: Desc)], map: "idx_backtestruns_user_created")
}

model backtesttrades {
  backtest_trade_id BigInt              @id @default(autoincrement())
  backtest_run_id   BigInt
  trade_type        backtest_trade_type
  trade_date        DateTime            @db.Date
  price             Decimal             @db.Decimal(18, 6)
  quantity          Decimal             @db.Decimal(18, 6)
  cash_after        Decimal             @db.Decimal(18, 6)
  equity_after      Decimal             @db.Decimal(18, 6)
  pnl_amount        Decimal?            @db.Decimal(18, 6)
  return_percent    Decimal?            @db.Decimal(10, 4)
  gross_amount      Decimal?            @db.Decimal(18, 6)
  fee_amount        Decimal?            @db.Decimal(18, 6)
  tax_amount        Decimal?            @db.Decimal(18, 6)
  net_amount        Decimal?            @db.Decimal(18, 6)
  position_after    Decimal?            @db.Decimal(18, 6)
  reason            String?             @db.VarChar(255)
  backtestruns      backtestruns        @relation(fields: [backtest_run_id], references: [backtest_run_id], onDelete: Cascade, map: "fk_BacktestTrades_BacktestRuns1")

  @@index([backtest_run_id, trade_date], map: "idx_backtesttrades_run_date")
}

enum transactions_transaction_type {
  BUY
  SELL
}

enum alert_rule_type {
  PRICE_ABOVE
  PRICE_BELOW
  PERCENT_CHANGE_UP
  PERCENT_CHANGE_DOWN
}

enum backtest_strategy_type {
  MOVING_AVERAGE_CROSS
  RSI_REVERSION
  BREAKOUT
}

enum backtest_trade_type {
  BUY
  SELL
}
